{
	"name": "url-shortner",
	"version": "0.0.0",
	"private": true,
	"scripts": {
		"predeploy": "npm run build:admin",
		"deploy": "wrangler deploy",
		"dev": "wrangler dev",
		"start": "wrangler dev",
		"admin:install": "npm install --prefix admin",
		"build:admin": "npm run build --prefix admin",
		"dev:admin": "npm run dev --prefix admin",
		"cf-typegen": "wrangler types",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest",
		"migrate:local": "wrangler d1 migrations apply url_shortener_db --local",
		"migrate": "wrangler d1 migrations apply url_shortener_db --remote"
	},
	"devDependencies": {
		"@cloudflare/vitest-pool-workers": "0.8.71",
		"@cloudflare/workers-types": "4.20260613.1",
		"typescript": "5.8.3",
		"vitest": "3.0.9",
		"wrangler": "4.100.0"
	},
	"dependencies": {
		"@hono/swagger-ui": "0.5.1",
		"hono": "4.7.8",
		"nanoid": "5.1.5"
	}
}
